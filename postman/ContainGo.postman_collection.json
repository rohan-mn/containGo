{
  "info": {
    "_postman_id": "bbb4bc0d-068c-49ec-9e4d-d6d5cbf1a66f",
    "name": "ContainGo End-to-End Demo",
    "description": "Guided ContainGo demonstration through the localhost Dashboard facade. Postman authenticates with a local demo token; Dashboard-to-Control-Plane and Dashboard-to-Report-Client calls use SPIFFE mTLS.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 - Reset Demo",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-ContainGo-Demo-Token",
            "value": "{{demo_token}}",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/demo-api/v1/reset",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "demo-api",
            "v1",
            "reset"
          ]
        },
        "description": "Creates a clean starting point: normal mode, active workload, zero current risk and cleared request counters."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Reset succeeded\", () => pm.response.to.have.status(200));",
              "const state = pm.response.json();",
              "pm.test(\"Report Client is active\", () => pm.expect(state.report_client.status).to.eql(\"active\"));",
              "pm.test(\"Mode is normal\", () => pm.expect(state.mode.mode).to.eql(\"normal\"));"
            ]
          }
        }
      ]
    },
    {
      "name": "01 - View Normal State",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-ContainGo-Demo-Token",
            "value": "{{demo_token}}",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/demo-api/v1/state",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "demo-api",
            "v1",
            "state"
          ]
        },
        "description": ""
      },
      "response": [],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "setTimeout(() => {}, 3000);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"State returned\", () => pm.response.to.have.status(200));",
              "const state = pm.response.json();",
              "pm.test(\"Normal request succeeds\", () => pm.expect(state.mode.successful_requests).to.be.above(0));",
              "pm.test(\"No transport failures\", () => pm.expect(state.mode.failed_requests).to.eql(0));"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Trigger Rapid Burst",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-ContainGo-Demo-Token",
            "value": "{{demo_token}}",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/demo-api/v1/mode",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "demo-api",
            "v1",
            "mode"
          ]
        },
        "description": "Sends a burst of allowed report requests to demonstrate request-rate risk scoring.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mode\": \"rapid\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Rapid mode enabled\", () => pm.response.to.have.status(200));",
              "pm.test(\"Mode is rapid\", () => pm.expect(pm.response.json().mode).to.eql(\"rapid\"));"
            ]
          }
        }
      ]
    },
    {
