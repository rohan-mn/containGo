        "url": {
          "raw": "{{base_url}}/demo-api/v1/mode",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "demo-api",
            "v1",
            "mode"
          ]
        },
        "description": "",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mode\": \"normal\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": [],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "setTimeout(() => {}, 2500);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Normal mode restored\", () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Start Attack",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-ContainGo-Demo-Token",
            "value": "{{demo_token}}",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/demo-api/v1/mode",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "demo-api",
            "v1",
            "mode"
          ]
        },
        "description": "Attempts /api/payment-details and /api/admin/config. OPA denies both and risk reaches the quarantine threshold.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mode\": \"attack\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Attack mode enabled\", () => pm.response.to.have.status(200));",
              "pm.environment.set(\"attack_started_at\", new Date().toISOString());"
            ]
          }
        }
      ]
    },
    {
      "name": "05 - Observe Automatic Quarantine",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-ContainGo-Demo-Token",
            "value": "{{demo_token}}",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/demo-api/v1/state",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "demo-api",
            "v1",
            "state"
          ]
        },
        "description": ""
      },
      "response": [],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "setTimeout(() => {}, 6500);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"State returned\", () => pm.response.to.have.status(200));",
              "const state = pm.response.json();",
              "pm.test(\"Report Client is quarantined\", () => pm.expect(state.report_client.status).to.eql(\"quarantined\"));",
              "pm.test(\"Risk reached threshold\", () => pm.expect(state.report_client.risk_score).to.be.at.least(70));",
              "pm.test(\"Order Client remains active\", () => pm.expect(state.order_client.status).to.eql(\"active\"));",
              "pm.test(\"Forbidden requests recorded\", () => pm.expect(state.mode.forbidden_requests).to.be.above(0));"
            ]
          }
        }
      ]
    },
    {
      "name": "06 - Inspect Complete Evidence",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-ContainGo-Demo-Token",
            "value": "{{demo_token}}",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/demo-api/v1/report-client/evidence",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "demo-api",
            "v1",
            "report-client",
            "evidence"
          ]
        },
        "description": ""
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Evidence returned\", () => pm.response.to.have.status(200));",
              "const evidence = pm.response.json();",
              "const incident = evidence.incidents[0];",
              "const total = incident.reasons.reduce((sum, reason) => sum + reason.points, 0);",
              "pm.test(\"Incident evidence equals quarantine score\", () => pm.expect(total).to.eql(incident.score_at_quarantine));",
              "pm.test(\"Security events are persisted\", () => pm.expect(evidence.events.length).to.be.above(0));"
            ]
          }
        }
      ]
    },
