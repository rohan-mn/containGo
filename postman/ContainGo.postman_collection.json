          ]
        },
        "description": ""
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Release succeeded\", () => pm.response.to.have.status(200));",
              "const state = pm.response.json();",
              "pm.test(\"Report Client is active\", () => pm.expect(state.report_client.status).to.eql(\"active\"));",
              "pm.test(\"Risk is reset\", () => pm.expect(state.report_client.risk_score).to.eql(0));",
              "pm.test(\"Mode is normal\", () => pm.expect(state.mode.mode).to.eql(\"normal\"));"
            ]
          }
        }
      ]
    },
    {
      "name": "08 - Verify Normal Traffic Resumes",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-ContainGo-Demo-Token",
            "value": "{{demo_token}}",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/demo-api/v1/state",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "demo-api",
            "v1",
            "state"
          ]
        },
        "description": ""
      },
      "response": [],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "setTimeout(() => {}, 3500);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"State returned\", () => pm.response.to.have.status(200));",
              "const state = pm.response.json();",
              "pm.test(\"Report Client remains active\", () => pm.expect(state.report_client.status).to.eql(\"active\"));",
              "pm.test(\"Latest request is allowed report route\", () => pm.expect(state.mode.last_path).to.eql(\"/api/reports\"));",
              "pm.test(\"Latest status is HTTP 200\", () => pm.expect(state.mode.last_status).to.eql(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "09 - List All Workloads",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-ContainGo-Demo-Token",
            "value": "{{demo_token}}",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
