          ]
        },
        "description": ""
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Workloads returned\", () => pm.response.to.have.status(200));",
              "const workloads = pm.response.json().workloads;",
              "pm.test(\"Seven workloads are registered\", () => pm.expect(workloads.length).to.eql(7));",
              "pm.test(\"Every workload has a SPIFFE ID\", () => workloads.forEach(w => pm.expect(w.spiffe_id).to.match(/^spiffe:\\/\\//)));"
            ]
          }
        }
      ]
    }
  ],
